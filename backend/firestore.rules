rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidArticle() {
      let data = request.resource.data;
      return data.keys().hasAll([
        'title', 'description', 'content', 'author',
        'sourceName', 'sourceId', 'category', 'thumbnailURL',
        'publishedAt', 'url', 'isBreaking', 'tags', 'views'
      ])
      && data.title is string && data.title.size() > 0
      && data.description is string
      && data.content is string
      && data.category in ['general','technology','sports','business','entertainment','health','science']
      && data.thumbnailURL is string
      && data.isBreaking is bool
      && data.tags is list
      && data.views is number;
    }

    // ── Articles collection ───────────────────────────────────────────────────

    match /articles/{articleId} {
      // Anyone (even unauthenticated) can read articles
      allow read: if true;

      // Only authenticated users can create/update/delete articles
      // In production, restrict further to admin claims:
      // request.auth.token.admin == true
      allow create: if isAuthenticated() && isValidArticle();
      allow update: if isAuthenticated() && isValidArticle();
      allow delete: if isAuthenticated();
    }

    // ── Categories collection ─────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── User-specific data (bookmarks) ────────────────────────────────────────

    match /users/{userId} {
      // Users can only read/write their own document
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      match /bookmarks/{bookmarkId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
